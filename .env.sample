# Diun Dispatcher Configuration

# Apprise URLs for notifications (comma-separated)
# Examples: pover://userkey@apptoken, ntfy://ntfy.example.com/topic
APPRISE_URLS=

# Webhook secret for Diun -> Dispatcher authentication
WEBHOOK_SECRET=

# Coolify API configuration
COOLIFY_URL=https://coolify.example.com
COOLIFY_TOKEN=

# Dispatcher public URL (for deploy links in notifications)
DISPATCHER_URL=https://dispatcher.example.com

# Container ignore list (comma-separated container names to skip)
IGNORE_CONTAINERS=
